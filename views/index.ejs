<!DOCTYPE html>
<html>
<head>
<title><%= title || "Auth Page" %></title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
    background: linear-gradient(135deg,#667eea,#764ba2);
    height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    font-family:sans-serif;
}

.auth-container{
    width:420px;
    background:white;
    border-radius:15px;
    padding:40px;
    box-shadow:0 20px 40px rgba(0,0,0,0.2);
}

.tabs{
    display:flex;
    background:#f1f1f1;
    border-radius:10px;
    margin-bottom:25px;
    overflow:hidden;
    position:relative;
}

.slider{
    position:absolute;
    width:50%;
    height:100%;
    background:#0d6efd;
    border-radius:10px;
    transition:all .4s ease;
}

.tabs button{
    flex:1;
    border:none;
    background:none;
    padding:10px;
    font-weight:600;
    z-index:1;
    color:#333;
}

.tabs button.active{
    color:white;
}

form{
    transition:opacity .3s ease, transform .3s ease;
}

.hidden{
    display:none;
}

input{
    transition:.2s;
}

input:focus{
    transform:scale(1.02);
}

button[type="submit"]{
    transition:.25s;
}

button[type="submit"]:hover{
    transform:translateY(-2px);
}
</style>

</head>
<body>

<div class="auth-container">

<div class="tabs">
<div class="slider" id="slider"></div>

<button id="loginTab" class="active" onclick="showLogin()">Login</button>
<button id="signupTab" onclick="showSignup()">Sign Up</button>
</div>

<% if(typeof message !== "undefined" && message){ %>
<div class="alert alert-info text-center">
<%= message %>
</div>
<% } %>

<form id="loginForm" method="POST" action="/login">

<h4 class="mb-3 text-center">Welcome Back</h4>

<input class="form-control mb-3" name="username" placeholder="Username" required>

<input class="form-control mb-3" type="password" name="password" placeholder="Password" required>

<button class="btn btn-primary w-100">Login</button>

</form>


<form id="signupForm" method="POST" action="/signup" class="hidden">

<h4 class="mb-3 text-center">Create Account</h4>

<input class="form-control mb-3" name="username" placeholder="Username" required>

<input class="form-control mb-3" type="password" name="password" placeholder="Password" required>

<button class="btn btn-success w-100">Create Account</button>

</form>

</div>

<script src="/script.js"></script>


</body>
</html>