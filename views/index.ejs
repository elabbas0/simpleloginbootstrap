<!DOCTYPE html>
<html lang="en">
<head>
<title><%= title || "Auth Page" %></title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
  :root {
    --green-deep: #2d4a35;
    --green-mid: #4a7c59;
    --green-light: #7aab8a;
    --cream: #f7f5f0;
    --warm-white: #fdfcf9;
    --text-dark: #1a1f1c;
    --text-mid: #5a6360;
    --text-light: #9aada6;
    --accent: #3d7a52;
    --border: #e2ded7;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    height: 100vh;
    display: flex;
    background: var(--warm-white);
    overflow: hidden;
  }

  /* ── LEFT PANEL ── */
  .left-panel {
    flex: 0 0 48%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 72px;
    background: var(--warm-white);
    position: relative;
    z-index: 2;
  }

  .form-wrap {
    width: 100%;
    max-width: 360px;
    animation: fadeUp .6s ease both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .brand-mark {
    width: 36px;
    height: 36px;
    background: var(--green-deep);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 44px;
  }

  .brand-mark svg { width: 20px; height: 20px; }

  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem;
    font-weight: 500;
    color: var(--text-dark);
    line-height: 1.15;
    margin-bottom: 6px;
    letter-spacing: -.01em;
  }

  .subtitle {
    font-size: .82rem;
    color: var(--text-mid);
    margin-bottom: 36px;
    font-weight: 300;
    letter-spacing: .01em;
  }

  /* Tabs */
  .tab-row {
    display: flex;
    gap: 0;
    background: var(--cream);
    border-radius: 10px;
    padding: 4px;
    margin-bottom: 28px;
    position: relative;
  }

  .tab-slider {
    position: absolute;
    top: 4px;
    left: 4px;
    width: calc(50% - 4px);
    height: calc(100% - 8px);
    background: white;
    border-radius: 7px;
    transition: transform .35s cubic-bezier(.4,0,.2,1);
    box-shadow: 0 1px 4px rgba(0,0,0,.08);
  }

  .tab-row.signup-active .tab-slider {
    transform: translateX(100%);
  }

  .tab-btn {
    flex: 1;
    border: none;
    background: none;
    padding: 9px 0;
    font-family: 'DM Sans', sans-serif;
    font-size: .8rem;
    font-weight: 500;
    color: var(--text-mid);
    cursor: pointer;
    position: relative;
    z-index: 1;
    transition: color .25s;
    letter-spacing: .03em;
    text-transform: uppercase;
  }

  .tab-btn.active { color: var(--text-dark); }

  /* Inputs */
  .field-group { margin-bottom: 16px; }

  .field-label {
    font-size: .72rem;
    font-weight: 500;
    color: var(--text-mid);
    text-transform: uppercase;
    letter-spacing: .08em;
    display: block;
    margin-bottom: 7px;
  }

  .field-input {
    width: 100%;
    border: 1.5px solid var(--border);
    border-radius: 9px;
    padding: 11px 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: .88rem;
    color: var(--text-dark);
    background: var(--warm-white);
    outline: none;
    transition: border-color .2s, box-shadow .2s;
  }

  .field-input::placeholder { color: var(--text-light); }

  .field-input:focus {
    border-color: var(--green-mid);
    box-shadow: 0 0 0 3px rgba(74,124,89,.1);
  }

  .field-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 7px;
  }

  .forgot-link {
    font-size: .75rem;
    color: var(--green-mid);
    text-decoration: none;
    font-weight: 400;
  }
  .forgot-link:hover { color: var(--green-deep); }

  /* Remember */
  .remember-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 22px;
  }

  .remember-row input[type="checkbox"] {
    width: 15px; height: 15px;
    accent-color: var(--green-deep);
    cursor: pointer;
  }

  .remember-row label {
    font-size: .78rem;
    color: var(--text-mid);
    cursor: pointer;
  }

  /* Submit */
  .btn-submit {
    width: 100%;
    padding: 13px;
    border: none;
    border-radius: 10px;
    background: var(--green-deep);
    color: white;
    font-family: 'DM Sans', sans-serif;
    font-size: .88rem;
    font-weight: 500;
    letter-spacing: .03em;
    cursor: pointer;
    transition: background .2s, transform .15s, box-shadow .2s;
    margin-bottom: 18px;
  }

  .btn-submit:hover {
    background: var(--green-mid);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(45,74,53,.25);
  }

  /* Divider */
  .or-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .or-row::before, .or-row::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .or-row span {
    font-size: .72rem;
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: .1em;
  }

  /* Social buttons */
  .social-row {
    display: flex;
    gap: 10px;
    margin-bottom: 28px;
  }

  .btn-social {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 14px;
    border: 1.5px solid var(--border);
    border-radius: 9px;
    background: white;
    font-family: 'DM Sans', sans-serif;
    font-size: .78rem;
    font-weight: 500;
    color: var(--text-dark);
    cursor: pointer;
    transition: border-color .2s, box-shadow .2s, transform .15s;
    text-decoration: none;
  }

  .btn-social:hover {
    border-color: #bbb;
    box-shadow: 0 2px 8px rgba(0,0,0,.07);
    transform: translateY(-1px);
    color: var(--text-dark);
  }

  .btn-social svg { flex-shrink: 0; }

  /* Footer text */
  .footer-text {
    text-align: center;
    font-size: .78rem;
    color: var(--text-mid);
  }

  .footer-text a {
    color: var(--green-mid);
    text-decoration: none;
    font-weight: 500;
  }
  .footer-text a:hover { color: var(--green-deep); }

  /* Form visibility */
  .form-body { animation: fadeUp .3s ease both; }
  .form-body.hidden { display: none; }

  /* Alert */
  .alert-info {
    background: #eef6f1;
    border: 1px solid #b8dcc5;
    border-radius: 9px;
    padding: 10px 14px;
    font-size: .82rem;
    color: var(--green-deep);
    margin-bottom: 20px;
    text-align: center;
  }

  /* ── RIGHT PANEL ── */
  .right-panel {
    flex: 1;
    position: relative;
    overflow: hidden;
    background: #c8d8c2;
  }

  .right-panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, rgba(45,74,53,.18) 0%, rgba(122,171,138,.08) 60%, transparent 100%);
    z-index: 1;
  }

  /* SVG botanical illustration */
  .botanical-wrap {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .plant-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Decorative card on right */
  .overlay-card {
    position: absolute;
    bottom: 48px;
    left: 44px;
    background: rgba(255,255,255,.88);
    backdrop-filter: blur(12px);
    border-radius: 14px;
    padding: 20px 24px;
    z-index: 2;
    max-width: 240px;
    box-shadow: 0 8px 32px rgba(0,0,0,.1);
  }

  .overlay-card p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem;
    color: var(--text-dark);
    line-height: 1.45;
    font-style: italic;
    margin-bottom: 10px;
  }

  .overlay-card .dot-row {
    display: flex; gap: 5px;
  }

  .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green-light);
  }

  .dot:first-child { background: var(--green-deep); }
  .dot:nth-child(2) { background: var(--green-mid); }
</style>
</head>
<body>

<!-- ══ LEFT ══ -->
<div class="left-panel">
  <div class="form-wrap">

    <!-- Brand -->
    <div class="brand-mark">
      <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 2C10 2 4 7 4 12C4 15.31 6.69 18 10 18C13.31 18 16 15.31 16 12C16 7 10 2 10 2Z" fill="white" opacity=".9"/>
        <path d="M10 6C10 6 13 9.5 13 12C13 13.65 11.65 15 10 15" stroke="rgba(255,255,255,.5)" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
    </div>

    <h1>Welcome<br>back!</h1>
    <p class="subtitle">Enter your credentials to access your account</p>

    <!-- Tabs -->
    <div class="tab-row" id="tabRow">
      <div class="tab-slider"></div>
      <button class="tab-btn active" id="loginTab" onclick="showLogin()">Login</button>
      <button class="tab-btn" id="signupTab" onclick="showSignup()">Sign Up</button>
    </div>

    <!-- Alert (EJS) -->
    <% if(typeof message !== "undefined" && message){ %>
    <div class="alert-info"><%= message %></div>
    <% } %>

    <!-- ── LOGIN FORM ── -->
    <div class="form-body" id="loginForm">
      <form method="POST" action="/login">

        <div class="field-group">
          <label class="field-label" for="login-username">Username</label>
          <input class="field-input" id="login-username" type="text" name="username" placeholder="Enter your username" required>
        </div>

        <div class="field-group">
          <div class="field-row">
            <label class="field-label" for="login-pw" style="margin-bottom:0">Password</label>
            <a href="#" class="forgot-link">Forgot password</a>
          </div>
          <input class="field-input" id="login-pw" type="password" name="password" placeholder="••••••••" required>
        </div>

        <div class="remember-row">
          <input type="checkbox" id="remember" name="remember">
          <label for="remember">Remember for 30 days</label>
        </div>

        <button type="submit" class="btn-submit">Login</button>

        <div class="or-row"><span>or</span></div>

        <div class="social-row">
          <a href="#" class="btn-social">
            <!-- Google icon -->
            <svg width="16" height="16" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Sign in with Google
          </a>
          <a href="#" class="btn-social">
            <!-- Apple icon -->
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98l-.09.06c-.22.15-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.77M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            Sign in with Apple
          </a>
        </div>

        <p class="footer-text">Don't have an account? <a href="#" onclick="showSignup();return false;">Sign Up</a></p>

      </form>
    </div>

    <!-- ── SIGNUP FORM ── -->
    <div class="form-body hidden" id="signupForm">
      <form method="POST" action="/signup">

        <div class="field-group">
          <label class="field-label" for="signup-user">Username</label>
          <input class="field-input" id="signup-user" name="username" placeholder="Choose a username" required>
        </div>

        <div class="field-group">
          <label class="field-label" for="signup-pw">Password</label>
          <input class="field-input" id="signup-pw" type="password" name="password" placeholder="Create a password" required>
        </div>

        <div style="margin-bottom:22px"></div>

        <button type="submit" class="btn-submit">Create Account</button>

        <div class="or-row"><span>or</span></div>

        <div class="social-row">
          <a href="#" class="btn-social">
            <svg width="16" height="16" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Sign up with Google
          </a>
          <a href="#" class="btn-social">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98l-.09.06c-.22.15-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.77M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
            Sign up with Apple
          </a>
        </div>

        <p class="footer-text">Already have an account? <a href="#" onclick="showLogin();return false;">Login</a></p>

      </form>
    </div>

  </div>
</div>

<!-- ══ RIGHT ══ -->
<div class="right-panel">
  <div class="botanical-wrap">
    <!-- SVG monstera / botanical illustration -->
    <svg class="plant-svg" viewBox="0 0 600 800" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
      <rect width="600" height="800" fill="#c4d4be"/>

      <!-- Background organic shapes -->
      <ellipse cx="420" cy="200" rx="280" ry="220" fill="#b8ccb2" opacity=".6"/>
      <ellipse cx="150" cy="600" rx="220" ry="180" fill="#afc1a8" opacity=".5"/>

      <!-- Large monstera leaf 1 -->
      <g transform="translate(300,400) rotate(-15)">
        <path d="M0,-220 C60,-200 130,-150 150,-60 C170,30 140,120 60,160 C20,180 -40,170 -80,130 C-130,80 -150,-10 -130,-100 C-110,-190 -60,-240 0,-220Z"
          fill="#3d6b49" opacity=".9"/>
        <!-- Leaf holes -->
        <ellipse cx="40" cy="-40" rx="28" ry="20" transform="rotate(-20,40,-40)" fill="#c4d4be"/>
        <ellipse cx="-30" cy="60" rx="22" ry="16" transform="rotate(15,-30,60)" fill="#c4d4be"/>
        <ellipse cx="80" cy="50" rx="18" ry="13" transform="rotate(-10,80,50)" fill="#c4d4be"/>
        <!-- Midrib -->
        <path d="M0,-220 C10,-100 20,20 -20,160" stroke="#2d5238" stroke-width="3" fill="none" opacity=".7"/>
        <!-- Veins -->
        <path d="M-10,-120 C30,-80 60,-50 40,-40" stroke="#2d5238" stroke-width="1.5" fill="none" opacity=".5"/>
        <path d="M-5,-60 C25,-30 50,0 80,50" stroke="#2d5238" stroke-width="1.5" fill="none" opacity=".5"/>
        <path d="M-15,30 C-40,55 -50,75 -30,60" stroke="#2d5238" stroke-width="1.5" fill="none" opacity=".5"/>
      </g>

      <!-- Large monstera leaf 2 (behind) -->
      <g transform="translate(180,300) rotate(25)">
        <path d="M0,-180 C50,-160 110,-110 120,-30 C130,50 100,130 30,160 C-10,175 -60,160 -90,110 C-130,50 -140,-40 -110,-120 C-85,-190 -50,-200 0,-180Z"
          fill="#2d5238" opacity=".75"/>
        <ellipse cx="30" cy="-20" rx="24" ry="17" transform="rotate(-15,30,-20)" fill="#c4d4be" opacity=".8"/>
        <ellipse cx="-20" cy="70" rx="19" ry="13" transform="rotate(10,-20,70)" fill="#c4d4be" opacity=".8"/>
        <path d="M0,-180 C8,-80 12,30 -15,150" stroke="#255040" stroke-width="2.5" fill="none" opacity=".6"/>
      </g>

      <!-- Smaller accent leaf top right -->
      <g transform="translate(500,120) rotate(-30)">
        <path d="M0,-140 C40,-120 90,-80 95,-10 C100,50 70,110 10,130 C-20,140 -55,125 -70,85 C-100,30 -100,-50 -70,-110 C-45,-160 -40,-160 0,-140Z"
          fill="#4a7c59" opacity=".8"/>
        <ellipse cx="25" cy="-10" rx="20" ry="14" transform="rotate(-20,25,-10)" fill="#c4d4be" opacity=".8"/>
        <path d="M0,-140 C6,-60 8,20 -10,120" stroke="#2d5238" stroke-width="2" fill="none" opacity=".5"/>
      </g>

      <!-- Stem -->
      <path d="M300,620 C310,580 320,540 315,480 C310,420 300,380 300,400" stroke="#2d5238" stroke-width="8" fill="none" stroke-linecap="round" opacity=".7"/>
      <path d="M300,700 C295,650 300,620 300,620" stroke="#2d5238" stroke-width="10" fill="none" stroke-linecap="round" opacity=".6"/>

      <!-- Ground/pot hint -->
      <ellipse cx="300" cy="760" rx="90" ry="20" fill="#a8bda2" opacity=".4"/>
      <rect x="255" y="730" width="90" height="50" rx="6" fill="#8fa88a" opacity=".35"/>

      <!-- Light bokeh circles -->
      <circle cx="480" cy="80" r="45" fill="white" opacity=".06"/>
      <circle cx="520" cy="150" r="25" fill="white" opacity=".08"/>
      <circle cx="80" cy="180" r="35" fill="white" opacity=".05"/>
      <circle cx="440" cy="680" r="55" fill="white" opacity=".05"/>
    </svg>
  </div>

  <!-- Overlay quote card -->
  <div class="overlay-card">
    <p>"Grow where you are planted."</p>
    <div class="dot-row">
      <div class="dot"></div>
      <div class="dot"></div>
      <div class="dot"></div>
    </div>
  </div>
</div>

<script src="/script.js"></script>
<script>

</script>
</body>
</html>